# URL base del backend (requerida, sin trailing slash).
#
# Escenario 1 — Backend corriendo local en el mismo servidor (ej: IntelliJ):
#   Usar la IP de red del host, NO localhost (localhost apunta al contenedor).
#   BACKEND_URL=http://192.168.1.x:8080
#
# Escenario 2 — Backend en Docker en el mismo servidor (mismo docker-compose):
#   Usar el nombre del servicio definido en docker-compose.yml.
#   BACKEND_URL=http://backend:8080
#
# Escenario 3 — Backend en otro servidor:
#   BACKEND_URL=https://api.mi-dominio.com

BACKEND_URL=
